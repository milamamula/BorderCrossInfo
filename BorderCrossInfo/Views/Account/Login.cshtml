@{
    ViewBag.Title = "Prijava";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card p-4 shadow-sm">
                <div class="text-center mb-4">
                    <i class="fas fa-lock fa-2x mb-2" style="color: var(--gold);"></i>
                    <h3 class="font-weight-bold">Prijava na sistem</h3>
                </div>

                @using (Html.BeginForm())
                {
                    if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <div class="form-group mb-3">
                        <label class="font-weight-bold">Korisničko ime</label>
                        <input type="text" name="username" class="form-control" required placeholder="Unesi korisničko ime..." />
                    </div>

                    <div class="form-group mb-3">
                        <label class="font-weight-bold">Lozinka</label>
                        <input type="password" name="password" class="form-control" required placeholder="Unesi lozinku..." />
                    </div>

                    <div class="form-group mt-4 text-center">
                        <button type="submit" class="btn btn-success btn-lg px-5">
                            <i class="fas fa-sign-in-alt"></i> Prijavi se
                        </button>
                    </div>
                }

                <hr class="my-4">
                <div class="text-center">
                    <p class="mb-0">
                        Nemaš nalog?
                        <a href="@Url.Action("Register")" class="font-weight-bold" style="color: var(--pastel-blue);">
                            Registruj se ovde
                        </a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>