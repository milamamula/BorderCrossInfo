@{
    ViewBag.Title = "O aplikaciji";
}

<div class="container mt-5">
    <div class="jumbotron bg-dark text-white shadow-lg" style="border-left: 5px solid var(--gold);">
        <h1 class="display-4 font-weight-bold">BorderCross<span class="text-gold">Info</span></h1>
        <p class="lead">Pametno rešenje za modernog putnika.</p>
    </div>

    <div class="row mt-5">
        <div class="col-md-7">
            <h2 class="section-title mb-4">Vizija i Svrha</h2>
            <p class="text-justify leading-relaxed">
                U vremenu kada su granice ponekad usko grlo međunarodne trgovine i turizma,
                <strong>BorderCrossInfo</strong> služi kao centralni informacioni hab. Naš cilj je
                optimizacija saobraćaja kroz transparentnost podataka.
            </p>
            <p class="text-justify">
                Aplikacija koristi <strong>XML Data Engine</strong> arhitekturu, što omogućava
                visoku efikasnost u manipulaciji podacima bez potrebe za eksternim SQL serverima,
                čineći sistem autonomnim i brzim.
            </p>
        </div>
        <div class="col-md-5">
            <div class="card bg-light p-4 border-0 shadow-sm">
                <h4 class="font-weight-bold mb-3">Tehnički detalji</h4>
                <ul class="list-unstyled">
                    <li><i class="fas fa-code text-primary mr-2"></i> Framework: ASP.NET MVC</li>
                    <li><i class="fas fa-file-code text-success mr-2"></i> Data: XML Engine</li>
                    <li><i class="fas fa-paint-brush text-warning mr-2"></i> UI: Bootstrap / Custom CSS</li>
                    <li><i class="fas fa-check-double text-danger mr-2"></i> Validacija: Client & Server side</li>
                </ul>
            </div>
        </div>
    </div>
</div>